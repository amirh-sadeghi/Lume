{
  "name": "beautyshop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node --watch server/src/index.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start:api": "node server/src/index.js",
    "db:migrate": "node server/scripts/migrate.js",
    "db:seed": "node server/scripts/seed.js",
    "db:reset": "node server/scripts/reset.js",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.2.0",
    "vite": "^5.0.0"
  }
}
